private static void insertionSort(int[] angka) {
		for(int i = 1; i < angka.length; i++) {
			int temp = angka[i];
			int j = i - 1;
			while((j >= 0) && (angka[j] > temp)) {
			 	angka[j + 1] = angka[j];
			 	j--;
			}
			angka[j + 1] = temp;
		}
	}

