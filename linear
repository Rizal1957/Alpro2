class Main {
   public static void main(String[] args) {
    int [] numbers={1,3,5,7,9};
    int target=7;
    
    int index=linearsearch(numbers,target);
    if(index!=-1){
        System.out.println("Target ditemukan, index : "+index);
    }else System.out.println("Target tidak ditemukan//");
  }
  
  static int linearsearch(int [] n,int t){
      for(int i=0;i<n.length;i++){
          if(n[i]==t){
              return i;
          }
      }
      return -1;
  }
}
