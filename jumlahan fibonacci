import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner s=new Scanner(System.in);
	    System.out.println("contoh deret fibonacci : 0,1,1,2,3,5,8,... ");
		System.out.println("anda ingin mencari berapa jumlahan angka pertama dalam deret fibonacci? ");
		int n=s.nextInt();
		int[]deret=new int[n];
		deret [0]=0;
		deret [1]=1;
		int hasil=1;
		for(int i=2;i<n;i++){
		    deret[i]=deret[i-1]+deret[i-2];
		    hasil=hasil+deret[i];
		}
		System.out.println("Maka jumlahan dari "+n+" angka pertama pada deret fibonacci adalah "+hasil);
	}
}
